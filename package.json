{
	"name": "use-user-media-hook",
	"version": "1.0.1",
	"description": "Hook to access user audio and video devices",
	"homepage": "https://github.com/FrankMoreno/use-user-media-hook#readme",
	"bugs": {
		"url": "https://github.com/FrankMoreno/use-user-media-hook/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/FrankMoreno/use-user-media-hook.git"
	},
	"license": "ISC",
	"author": "Frank Moreno",
	"type": "module",
	"main": "./dist/useUserMedia.js",
	"types": "./dist/useUserMedia.d.ts",
	"exports": {
		".": {
			"import": "./dist/useUserMedia.js",
			"types": "./dist/useUserMedia.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"check": "biome check src/ tests/",
		"check:fix": "biome check src/ tests/ --fix",
		"lint": "biome lint src/",
		"lint:fix": "biome lint src/ tests/ --fix",
		"format": "biome format src/ tests/ --write",
		"test": "vitest run",
		"prepare": "npm run build"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@testing-library/react": "^16.3.2",
		"@types/jsdom": "^28.0.1",
		"@types/react": "^19.2.14",
		"jsdom": "^29.0.1",
		"react": "^19.2.4",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	},
	"peerDependencies": {
		"react": ">=18.0.0"
	},
	"engines": {
		"node": ">=20.0.0",
		"npm": ">=9.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"react",
		"getUserMedia",
		"useUserMedia",
		"hook",
		"media",
		"stream",
		"audio",
		"video"
	]
